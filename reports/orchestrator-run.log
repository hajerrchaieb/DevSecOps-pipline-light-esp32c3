#include <esp_log.h>
#include <stdlib.h>
#include <string.h>

#include <esp_matter.h>
#include <app_priv.h>
#include <common_macros.h>

// Define a class to encapsulate LED driver functionality
class LedDriver {
public:
    LedDriver(led_driver_handle_t handle) : handle_(handle) {}

    esp_err_t setPower(bool power) {
        // Use a safer alternative to strcpy
        char powerStr[10];
        strlcpy(powerStr, power ? "true" : "false", sizeof(powerStr));
        return led_driver_set_power(handle_, powerStr);
    }

    esp_err_t setBrightness(uint8_t brightness) {
        // Use a safer alternative to strcat
        char brightnessStr[10];
        strlcpy(brightnessStr, "brightness:", sizeof(brightnessStr));
        strlcat(brightnessStr, std::to_string(brightness).c_str(), sizeof(brightnessStr));
        return led_driver_set_brightness(handle_, brightnessStr);
    }

private:
    led_driver_handle_t handle_;
};

// Define a function to handle Matter attributes
